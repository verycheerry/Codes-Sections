#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

template <class T>
void randomSquareMatrix(T* arr, size_t len, int maxVal)
{
    srand((unsigned)time(nullptr));

    for (size_t i = 0; i < len; i++)
        arr[i] = rand() % maxVal;
}

int main()
{
    double arr[9];

    randomSquareMatrix(arr, 9, 10);

    for (int i = 0; i < 9; i++)
        cout << arr[i] << " ";

    return 0;
}
